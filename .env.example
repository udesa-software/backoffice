PORT=3001

# Base de datos (puede ser la misma instancia que users)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=udesamigos
DB_USER=postgres
DB_PASSWORD=postgres

# JWT para admins (DIFERENTE al JWT_SECRET que usa el servicio de users)
ADMIN_JWT_SECRET=backoffice_super_secret_change_me
JWT_EXPIRES_IN=8h

# URL pública del backoffice (para links en emails)
APP_URL=http://localhost:3001

# Dominio de email permitido para admins (dejar vacío para no restringir)
ALLOWED_EMAIL_DOMAIN=udesa.edu.ar

# SuperAdmin inicial (solo se usa si la tabla admins está vacía al arrancar)
INITIAL_SUPERADMIN_EMAIL=admin@udesa.edu.ar
INITIAL_SUPERADMIN_TEMP_PASSWORD=Admin1234!

# URL del microservicio de users (llamadas internas)
USERS_SERVICE_URL=http://users:3000

# H9: secreto compartido para llamadas internas entre microservicios
INTERNAL_SECRET=secret_secret_here

# SMTP (opcional — si no se configura, los emails se loguean en consola)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=backoffice@udesa.edu.ar
